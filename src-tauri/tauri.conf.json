{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Keeep",
  "version": "0.1.0",
  "identifier": "nl.keeep.app",
  "build": {
    "beforeDevCommand": "npm run server",
    "devUrl": "http://localhost:7433",
    "frontendDist": "../app"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Keeep",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "backgroundColor": "#12131a"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "msi", "nsis"],
    "category": "Finance",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
